{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Current Task",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": ["${input:programArgs}"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/cmake-setup",
            // "environment": [
            //     {
            //         "name": "PATH",
            //         "value": "${workspaceFolder}/msys64/ucrt64/bin;${env:PATH}"
            //     }
            // ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for GDB",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ],
    "inputs": [
        {
            "id": "programArgs",
            "type": "promptString",
            "description": "CLI arguments (leave blank if none)",
            "default": ""
        }
    ]
}
